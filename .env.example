# ============================================
# Nova AI Environment Configuration
# ============================================

# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to GitHub!

# --------------------------------------------
# Gemini AI Configuration
# Get your API key from: https://ai.google.dev/
# --------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# OpenRouter Configuration (Optional - for alternative models)
# Get your API key from: https://openrouter.ai/
# --------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --------------------------------------------
# Unsplash API (Optional - for slide images)
# Get free API key from: https://unsplash.com/developers
# Leave empty to use demo mode (50 requests/hour limit)
# --------------------------------------------
UNSPLASH_API_KEY=your_unsplash_api_key_here

# ============================================
# PAYOS PAYMENT CONFIGURATION (REQUIRED FOR PRO)
# ============================================
# Get your PayOS credentials from: https://payos.vn/
# These are required for the Pro subscription feature to work
# --------------------------------------------

# Your PayOS Client ID (from PayOS Dashboard)
PAYOS_CLIENT_ID=your_payos_client_id_here

# Your PayOS API Key (from PayOS Dashboard)
PAYOS_API_KEY=your_payos_api_key_here

# Your PayOS Checksum Key (from PayOS Dashboard)
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here

# ============================================
# IMPORTANT NOTES:
# ============================================
# 1. Never share or commit your actual .env file
# 2. Keep your API keys secure and rotate them regularly
# 3. For production, use environment-specific .env files
# 4. PayOS keys are required for Pro subscription payments
# 5. Gemini API key is required for AI chat functionality
# ============================================
